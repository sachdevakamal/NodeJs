<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Students Details</title>
</head>
<body>
    <h1>Students Details</h1>
    <ul>
        <% students.forEach(student => { %>
            <li><%= student.name %> - <%= student.age %> - <%= student.email %></li>
        <% }); %>
    </ul>
</body>
</html>