<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users</title>
</head>
<body>
    <h1>Users</h1>
    <ul>
        <% for (let user of users) { %>
            <li>
                <h3><%= user.name %></h3>
                <p>Email: <%= user.email %></p>
                <p>Age: <%= user.age %></p>
            </li>
        <% } %>
    </ul>
</body>
</html>